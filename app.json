{
  "expo": {
    "name": "MyCoffeeJourney-v2",
    "slug": "MyCoffeeJourney-v2",
    "scheme": "mycoffee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cup_brown.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/coffeecup.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B0D0C"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/coffeecup.png",
        "backgroundColor": "#3B0D0C"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
